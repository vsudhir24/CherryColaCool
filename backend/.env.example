# Local development
FLASK_DEBUG=true
PORT=8000

# Comma-separated frontend URLs allowed to call the API (add your Firebase Hosting URL after deploy)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Gemini (optional — AI briefs fall back to template text without a key)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
